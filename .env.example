# ============================================================================
# SignalPulse AI — Environment variables template
# ----------------------------------------------------------------------------
# 1. Copy this file to ".env"  (PowerShell:  Copy-Item .env.example .env)
# 2. Fill in the values below.
# 3. NEVER commit the real .env file (it is git-ignored).
# ============================================================================

# ---------------------------------------------------------------------------
# Neo4j database connection
# Local Docker/Desktop default URI is bolt://localhost:7687
# Set the password to whatever you chose when starting Neo4j.
# ---------------------------------------------------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-neo4j-password
NEO4J_DATABASE=neo4j

# ---------------------------------------------------------------------------
# LLM providers (free tiers — see README)
# GROQ_API_KEY     -> https://console.groq.com/keys          (primary; high throughput)
# MISTRAL_API_KEY  -> https://console.mistral.ai/            (fallback)
# DEEPSEEK_API_KEY -> https://platform.deepseek.com/api_keys (fallback)
# GOOGLE_API_KEY   -> https://aistudio.google.com/apikey     (fallback; ~20 req/day)
# NOTE: Free tiers still have daily/minute token limits. Keys do not expire from
# age alone — quotas reset on a schedule. Ask() tries each configured provider
# in order when one returns 429 / quota errors.
# ---------------------------------------------------------------------------
GOOGLE_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=
DEEPSEEK_API_KEY=

# Which provider the app uses first: groq | mistral | deepseek | gemini
LLM_PROVIDER=groq
GEMINI_MODEL=gemini-3.5-flash
GROQ_MODEL=llama-3.3-70b-versatile
MISTRAL_MODEL=mistral-small-latest
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ---------------------------------------------------------------------------
# Embedding model (runs locally, free). No key needed.
# ---------------------------------------------------------------------------
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384

# ---------------------------------------------------------------------------
# Data-source API keys (both free)
# NVD_API_KEY            -> https://nvd.nist.gov/developers/request-an-api-key
# REGULATIONS_GOV_API_KEY-> https://open.gsa.gov/api/regulationsgov/ (Sign up)
#                           (you may use DEMO_KEY for light testing)
# ---------------------------------------------------------------------------
NVD_API_KEY=
REGULATIONS_GOV_API_KEY=DEMO_KEY

# ---------------------------------------------------------------------------
# Pipeline tuning (safe defaults — change later if needed)
# ---------------------------------------------------------------------------
CHUNK_SIZE=800
CHUNK_OVERLAP=100
VECTOR_TOP_K=6
SIMILARITY_THRESHOLD=0.60
